{
  "expo": {
    "name": "AgapAI Mobile",
    "slug": "agapai-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/appstore.png",
    "scheme": "agapaimobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "icon": "./assets/images/appstore.png",
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#06112B",
        "foregroundImage": "./assets/images/playstore.png",
        "monochromeImage": "./assets/images/playstore.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/playstore.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/AgapAI-logo.png",
          "imageWidth": 230,
          "resizeMode": "contain",
          "backgroundColor": "#06112B",
          "dark": {
            "backgroundColor": "#06112B"
          }
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    }
  }
}
